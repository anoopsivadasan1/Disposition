library(shiny)
library(shinydashboard)
library(dplyr)
library(plotly)
library(DT)
#----------------------------------
# SAMPLE DATA (simulate Excel)
#----------------------------------
set.seed(123)
# Disposition data
disp_data <- data.frame(
STUDY = sample(c("Berg","Juni"), 200, TRUE),
STATUS = sample(c("Completed","Discontinued"), 200, TRUE),
REASON = sample(c("AE","Lack of efficacy","Withdrawal","Other"), 200, TRUE)
)
# AE data
ae_data <- data.frame(
STUDY = sample(c("Berg","Juni"), 200, TRUE),
AE_TERM = sample(c("Headache","Nausea","Fatigue","Infection"), 200, TRUE),
SEVERITY = sample(c("Mild","Moderate","Severe"), 200, TRUE)
)
# Exposure data
exp_data <- data.frame(
STUDY = sample(c("Berg","Juni"), 200, TRUE),
DOSE = sample(c("Low","Medium","High"), 200, TRUE),
DURATION = sample(1:100, 200, TRUE)
)
#----------------------------------
# MODULE 1: DISPOSITION
#----------------------------------
dispUI <- function(id){
ns <- NS(id)
tagList(
fluidRow(
box(width=6, title="Disposition Status", plotlyOutput(ns("pie"))),
box(width=6, title="Discontinuation Reasons", plotlyOutput(ns("bar")))
),
box(width=12, title="Disposition Table", DTOutput(ns("table")))
)
}
dispServer <- function(id, study){
moduleServer(id, function(input, output, session){
data <- reactive({
disp_data %>% filter(STUDY == study())
})
output$pie <- renderPlotly({
df <- data() %>% count(STATUS)
plot_ly(df, labels = ~STATUS, values = ~n, type = "pie")
})
output$bar <- renderPlotly({
df <- data() %>% count(REASON)
plot_ly(df, x = ~REASON, y = ~n, type = "bar")
})
output$table <- renderDT({
datatable(data())
})
})
}
#----------------------------------
# MODULE 2: ADVERSE EVENTS
#----------------------------------
aeUI <- function(id){
ns <- NS(id)
tagList(
fluidRow(
box(width=6, title="AE Terms", plotlyOutput(ns("bar"))),
box(width=6, title="Severity", plotlyOutput(ns("pie")))
),
box(width=12, DTOutput(ns("table")))
)
}
aeServer <- function(id, study){
moduleServer(id, function(input, output, session){
data <- reactive({
ae_data %>% filter(STUDY == study())
})
output$bar <- renderPlotly({
df <- data() %>% count(AE_TERM)
plot_ly(df, x = ~AE_TERM, y = ~n, type = "bar")
})
output$pie <- renderPlotly({
df <- data() %>% count(SEVERITY)
plot_ly(df, labels = ~SEVERITY, values = ~n, type = "pie")
})
output$table <- renderDT({
datatable(data())
})
})
}
#----------------------------------
# MODULE 3: EXPOSURE
#----------------------------------
expUI <- function(id){
ns <- NS(id)
tagList(
fluidRow(
box(width=6, title="Dose Distribution", plotlyOutput(ns("pie"))),
box(width=6, title="Duration", plotlyOutput(ns("hist")))
),
box(width=12, DTOutput(ns("table")))
)
}
expServer <- function(id, study){
moduleServer(id, function(input, output, session){
data <- reactive({
exp_data %>% filter(STUDY == study())
})
output$pie <- renderPlotly({
df <- data() %>% count(DOSE)
plot_ly(df, labels = ~DOSE, values = ~n, type = "pie")
})
output$hist <- renderPlotly({
plot_ly(data(), x = ~DURATION, type = "histogram")
})
output$table <- renderDT({
datatable(data())
})
})
}
#----------------------------------
# MASTER UI
#----------------------------------
ui <- dashboardPage(
dashboardHeader(title = "Clinical Dashboard"),
dashboardSidebar(
sidebarMenu(
menuItem("Disposition", tabName = "disp"),
menuItem("Adverse Events", tabName = "ae"),
menuItem("Exposure", tabName = "exp")
),
selectInput("study", "Select Study",
choices = c("Berg","Juni"))
),
dashboardBody(
tabItems(
tabItem(tabName = "disp", dispUI("disp")),
tabItem(tabName = "ae", aeUI("ae")),
tabItem(tabName = "exp", expUI("exp"))
)
)
)
#----------------------------------
# MASTER SERVER
#----------------------------------
server <- function(input, output, session){
study <- reactive({ input$study })
dispServer("disp", study)
aeServer("ae", study)
expServer("exp", study)
}
#----------------------------------
# RUN APP
#----------------------------------
shinyApp(ui, server)
